# Telegram API Credentials
API_ID=31495607
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# Owner and Admin Configuration
OWNER_IDS=123456789,987654321
ALLOW_DEFAULTS=0

# MongoDB Configuration
